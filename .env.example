# Public/runtime app metadata served through /api/config
APP_NAME=CoinCoach
APP_ENV=production
SUPPORT_EMAIL=support@coincoach.example

# Server-only secret. Never expose this value in frontend HTML/JS.
API_KEY=replace_with_real_secret

# Optional AI endpoint config
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
